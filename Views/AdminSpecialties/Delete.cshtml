@model ClinicBookingMVC.Models.Specialty
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xóa chuyên khoa";
}

<div class="admin-section-card">
    <h4>Xác nhận vô hiệu hóa</h4>
    <div class="alert alert-warning">
        <h5>@Model.SpecialtyName</h5>
        <p>@Model.Description</p>
        <p class="mb-0">Bạn có chắc muốn vô hiệu hóa chuyên khoa này?</p>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="SpecialtyId" />
        <div class="btn-group">
            <button type="submit" class="btn btn-danger">Vô hiệu hóa</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </div>
    </form>
</div>
