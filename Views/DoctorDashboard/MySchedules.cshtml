@model IEnumerable<ClinicBookingMVC.Models.DoctorSchedule>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Lịch làm việc của tôi";
}

<div class="admin-section-card mb-4">
    <form method="get" asp-action="MySchedules">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Từ ngày</label>
                <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary"><i class="bi bi-search me-1"></i>Lọc</button>
            </div>
        </div>
    </form>
</div>

<div class="admin-section-card">
    <h5 class="mb-3"><i class="bi bi-calendar-week me-2"></i>Lịch làm việc</h5>

    @if (Model.Any())
    {
        <div class="row g-3">
            @foreach (var schedule in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100 @(schedule.IsAvailable ? "" : "border-secondary opacity-75")">
                        <div class="card-body">
                            <h6 class="card-title">
                                <i class="bi bi-calendar3 me-1"></i>
                                @schedule.WorkDate.ToString("dddd, dd/MM/yyyy")
                            </h6>
                            <div class="d-flex gap-2 mb-2">
                                @if (schedule.IsAvailable)
                                {
                                    <span class="badge bg-success">Có sẵn</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Không khả dụng</span>
                                }
                                <span class="badge bg-info">@schedule.DoctorScheduleSlots.Count slot</span>
                            </div>
                            @if (!string.IsNullOrEmpty(schedule.Notes))
                            {
                                <p class="card-text text-muted small">@schedule.Notes</p>
                            }
                        </div>
                        <div class="card-footer bg-transparent">
                            <a asp-action="ScheduleDetails" asp-route-id="@schedule.ScheduleId"
                               class="btn btn-outline-primary btn-sm w-100">
                                <i class="bi bi-eye me-1"></i>Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center text-muted py-4">
            <i class="bi bi-calendar-x fs-1"></i>
            <p class="mt-2">Không có lịch làm việc nào.</p>
        </div>
    }
</div>
