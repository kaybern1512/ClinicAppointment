@model IEnumerable<ClinicBookingMVC.ViewModels.Admin.AdminDoctorListItemViewModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý bác sĩ";
}

<div class="admin-section-card mb-4">
    <form method="get" asp-action="Index">
        <div class="row g-3">
            <div class="col-md-5">
                <label class="form-label">Tìm theo tên bác sĩ</label>
                <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Lọc theo chuyên khoa</label>
                <select name="specialtyId" asp-items="ViewBag.SpecialtyId" class="form-select">
                    <option value="">-- Tất cả chuyên khoa --</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-primary w-100">Lọc dữ liệu</button>
            </div>
        </div>
    </form>
</div>

<div class="admin-section-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Danh sách bác sĩ</h5>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Thêm mới
        </a>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ảnh</th>
                    <th>Họ tên</th>
                    <th>Chuyên khoa</th>
                    <th>Kinh nghiệm</th>
                    <th>Hoạt động</th>
                    <th>Nổi bật</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DoctorId</td>
                        <td>
                            <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? "https://via.placeholder.com/60x60?text=Dr" : item.ImageUrl)"
                                 class="admin-thumb" />
                        </td>
                        <td>@item.FullName</td>
                        <td>@item.SpecialtyName</td>
                        <td>@item.ExperienceYears năm</td>
                        <td>
                            <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <span class="badge @(item.IsFeatured ? "bg-primary" : "bg-light text-dark")">
                                @(item.IsFeatured ? "Featured" : "Normal")
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.DoctorId" class="btn btn-outline-secondary btn-sm">Chi tiết</a>
                                <a asp-action="Edit" asp-route-id="@item.DoctorId" class="btn btn-primary btn-sm">Sửa</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>