@model IEnumerable<ClinicBookingMVC.ViewModels.Admin.AdminDoctorListItemViewModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý bác sĩ";
}

<div class="admin-section-card mb-4 shadow-sm border-0">
    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-search fs-4 me-2 text-primary"></i>
        <h5 class="mb-0 fw-bold">Bộ lọc bác sĩ</h5>
    </div>
    <form method="get" asp-action="Index">
        <div class="row g-3">
            <div class="col-md-5">
                <label class="form-label admin-form-label">Tên bác sĩ</label>
                <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control admin-input border-0 bg-light shadow-sm" placeholder="Nhập tên bác sĩ cần tìm..." />
            </div>
            <div class="col-md-4">
                <label class="form-label admin-form-label">Chuyên khoa</label>
                <select name="specialtyId" asp-items="ViewBag.SpecialtyId" class="form-select admin-input border-0 bg-light shadow-sm">
                    <option value="">-- Tất cả chuyên khoa --</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-primary w-100 shadow-sm"><i class="bi bi-funnel me-1"></i>Lọc dữ liệu</button>
            </div>
        </div>
    </form>
</div>

<div class="admin-section-card border-0 shadow-sm overflow-hidden p-0">
    <div class="bg-success bg-opacity-10 p-4 border-bottom d-flex justify-content-between align-items-center">
        <div>
            <h5 class="fw-bold mb-1 text-success"><i class="bi bi-person-heart me-2"></i>Danh sách bác sĩ</h5>
            <p class="text-muted mb-0 small">Quản lý hồ sơ và thông tin bác sĩ</p>
        </div>
        <a asp-action="Create" class="btn btn-success btn-sm rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Thêm bác sĩ
        </a>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ảnh</th>
                    <th>Họ tên</th>
                    <th>Chuyên khoa</th>
                    <th>Kinh nghiệm</th>
                    <th>Hoạt động</th>
                    <th>Nổi bật</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DoctorId</td>
                        <td>
                            <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? "https://via.placeholder.com/60x60?text=Dr" : item.ImageUrl)"
                                 class="admin-thumb" />
                        </td>
                        <td>@item.FullName</td>
                        <td>@item.SpecialtyName</td>
                        <td>@item.ExperienceYears năm</td>
                        <td>
                            <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <span class="badge @(item.IsFeatured ? "bg-primary" : "bg-light text-dark")">
                                @(item.IsFeatured ? "Featured" : "Normal")
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.DoctorId" class="btn btn-outline-secondary btn-sm">Chi tiết</a>
                                <a asp-action="Edit" asp-route-id="@item.DoctorId" class="btn btn-primary btn-sm">Sửa</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>