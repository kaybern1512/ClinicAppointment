@model ClinicBookingMVC.ViewModels.Admin.AdminDoctorListItemViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết bác sĩ";
}

<div class="admin-details-card">
    <div class="row g-4">
        <div class="col-md-4">
            <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "https://via.placeholder.com/500x400?text=Doctor" : Model.ImageUrl)"
                 class="img-fluid rounded-4 shadow-sm" />
        </div>
        <div class="col-md-8">
            <h3>@Model.FullName</h3>
            <p><strong>Chuyên khoa:</strong> @Model.SpecialtyName</p>
            <p><strong>Kinh nghiệm:</strong> @Model.ExperienceYears năm</p>
            <p><strong>Hoạt động:</strong> @(Model.IsActive ? "Active" : "Inactive")</p>
            <p><strong>Nổi bật:</strong> @(Model.IsFeatured ? "Có" : "Không")</p>
            <p><strong>Lịch làm việc:</strong> @ViewBag.WorkingTime</p>
            <p><strong>Mô tả:</strong> @ViewBag.Description</p>

            <div class="mt-4 d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.DoctorId" class="btn btn-primary">Chỉnh sửa</a>
                <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
            </div>
        </div>
    </div>
</div>