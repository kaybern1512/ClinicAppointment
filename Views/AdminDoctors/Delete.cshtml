@model ClinicBookingMVC.Models.Doctor
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xóa bác sĩ";
}

<div class="admin-section-card">
    <h4>Xác nhận vô hiệu hóa</h4>
    <div class="alert alert-warning">
        <h5>@Model.FullName</h5>
        <p><strong>Chuyên khoa:</strong> @Model.Specialty?.SpecialtyName</p>
        <p><strong>Kinh nghiệm:</strong> @Model.ExperienceYears năm</p>
        <p class="mb-0">Bạn có chắc muốn vô hiệu hóa bác sĩ này? (Lịch sẽ không hiển thị nữa)</p>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="DoctorId" />
        <div class="btn-group">
            <button type="submit" class="btn btn-danger">Vô hiệu hóa</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </div>
    </form>
</div>
