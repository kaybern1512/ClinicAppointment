@model ClinicBookingMVC.ViewModels.Admin.AdminContactDetailsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết tin nhắn";
}

<div class="admin-details-card">
    <h4 class="mb-4">Chi tiết tin nhắn liên hệ</h4>

    <div class="row g-3">
        <div class="col-md-6"><strong>Họ tên:</strong> @Model.FullName</div>
        <div class="col-md-6"><strong>Email:</strong> @Model.Email</div>
        <div class="col-md-6"><strong>Ngày gửi:</strong> @Model.SentAt.ToString("dd/MM/yyyy HH:mm")</div>
        <div class="col-12">
            <strong>Nội dung:</strong>
            <div class="message-box mt-2">@Model.Message</div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
    </div>
</div>