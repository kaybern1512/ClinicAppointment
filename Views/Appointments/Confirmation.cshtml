@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Xác nhận đặt lịch";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center mb-5 p-4 bg-light rounded-3">
                <i class="bi bi-check-circle-fill text-success fs-1 mb-3"></i>
                <h2 class="text-success">Đặt lịch thành công!</h2>
                <p class="lead text-muted">Lịch hẹn của bạn đã được gửi đến bác sĩ. Chúng tôi sẽ thông báo khi được xác nhận.</p>
            </div>
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-calendar-event me-2"></i>Tóm tắt lịch hẹn #1246</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6"><strong>Bác sĩ:</strong> BS. Nguyễn Văn A (Nội khoa)</div>
                        <div class="col-md-6"><strong>Thời gian:</strong> 20/10/2024 14:00</div>
                        <div class="col-md-6"><strong>Phí khám:</strong> 1,000,000 VND</div>
                        <div class="col-md-6"><strong>Trạng thái:</strong> <span class="badge bg-warning text-dark">PENDING</span></div>
                    </div>
                </div>
            </div>
            <div class="text-center">
                <a asp-controller="Payments" asp-action="Confirm" class="btn btn-primary px-5 mb-2 d-inline-block">Thanh toán ngay</a><br>
                <a asp-controller="Appointments" asp-action="MyAppointments" class="btn btn-outline-primary px-5">Xem lịch của tôi</a>
            </div>
        </div>
    </div>
</div>
