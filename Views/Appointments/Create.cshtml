@model AppointmentCreateViewModel
@{
    ViewData["Title"] = "Đặt lịch khám";
}

<style>
    .field-validation-error,
    .validation-summary-errors,
    .input-validation-error {
        display: none;
    }
</style>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm appointment-form-card">
            <div class="card-body p-4">
                <h2 class="mb-4">Đặt lịch khám</h2>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="PatientName" class="form-label"></label>
                            <input asp-for="PatientName" class="form-control" />
                            <span asp-validation-for="PatientName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="DateOfBirth" class="form-label"></label>
                            <input asp-for="DateOfBirth" class="form-control" />
                            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Gender" class="form-label"></label>
                            <select asp-for="Gender" class="form-select">
                                <option value="">-- Chọn giới tính --</option>
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            </select>
                            <span asp-validation-for="Gender" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SpecialtyId" class="form-label"></label>
                            <select asp-for="SpecialtyId" asp-items="Model.Specialties" class="form-select">
                                <option value="">-- Chọn chuyên khoa --</option>
                            </select>
                            <span asp-validation-for="SpecialtyId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DoctorId" class="form-label"></label>
                            <select asp-for="DoctorId" asp-items="Model.Doctors" class="form-select">
                                <option value="">-- Chọn bác sĩ --</option>
                            </select>
                            <span asp-validation-for="DoctorId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="AppointmentDate" class="form-label"></label>
                            <input asp-for="AppointmentDate" class="form-control" />
                            <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DoctorScheduleSlotId" class="form-label"></label>
                            <select asp-for="DoctorScheduleSlotId" asp-items="Model.ScheduleSlots" class="form-select">
                                <option value="">-- Chọn khung giờ --</option>
                            </select>
                            <span asp-validation-for="DoctorScheduleSlotId" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Symptoms" class="form-label"></label>
                            <textarea asp-for="Symptoms" class="form-control" rows="4" placeholder="Nhập triệu chứng hoặc ghi chú..."></textarea>
                            <span asp-validation-for="Symptoms" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Đặt lịch</button>
                        <button type="reset" class="btn btn-outline-secondary">Làm mới</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <h4 class="mb-3">Tóm tắt lịch hẹn</h4>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">Điền đầy đủ thông tin cá nhân</li>
                    <li class="list-group-item">Chọn chuyên khoa phù hợp</li>
                    <li class="list-group-item">Chọn bác sĩ mong muốn</li>
                    <li class="list-group-item">Chọn ngày và giờ khám</li>
                    <li class="list-group-item">Kiểm tra lại trước khi gửi</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            var $specialtySelect = $('#SpecialtyId');
            var $doctorSelect = $('#DoctorId');
            var $dateInput = $('#AppointmentDate');
            var $slotSelect = $('#DoctorScheduleSlotId');

            var minDate = new Date();
            var maxDate = new Date();
            maxDate.setDate(maxDate.getDate() + 7);

            function formatDate(date) {
                const year = date.getFullYear();
                const month = String(date.getMonth() + 1).padStart(2, '0');
                const day = String(date.getDate()).padStart(2, '0');
                return `${year}-${month}-${day}`;
            }

            $dateInput.attr('min', formatDate(minDate));
            $dateInput.attr('max', formatDate(maxDate));

            function resetDoctors() {
                $doctorSelect.html('<option value="">-- Chọn bác sĩ --</option>');
            }

            function resetSlots(message) {
                $slotSelect.html('<option value="">' + (message || '-- Chọn khung giờ --') + '</option>');
            }

            function loadDoctors(callback) {
                var specialtyId = $specialtySelect.val();

                resetDoctors();
                resetSlots();

                if (!specialtyId) {
                    return;
                }

                $.get('@Url.Action("GetDoctorsBySpecialty", "Appointments")',
                    { specialtyId: specialtyId },
                    function (data) {
                        resetDoctors();

                        if (data && data.length > 0) {
                            $.each(data, function (index, doctor) {
                                $doctorSelect.append($('<option/>', {
                                    value: doctor.value,
                                    text: doctor.text
                                }));
                            });
                        }

                        if (callback) callback();
                    }
                ).fail(function () {
                    resetDoctors();
                    resetSlots('-- Lỗi khi tải bác sĩ --');
                    if (typeof toastr !== 'undefined') {
                        toastr.error('Không thể tải danh sách bác sĩ.');
                    }
                });
            }

            function loadSlots() {
                var doctorId = $doctorSelect.val();
                var date = $dateInput.val();

                if (!doctorId || !date) {
                    resetSlots();
                    return;
                }

                resetSlots('-- Đang tải... --');

                $.get('@Url.Action("GetSlots", "Appointments")',
                    {
                        doctorId: doctorId,
                        appointmentDate: date
                    },
                    function (data) {
                        resetSlots();

                        if (data && data.length > 0) {
                            $.each(data, function (index, slot) {
                                $slotSelect.append($('<option/>', {
                                    value: slot.value,
                                    text: slot.text
                                }));
                            });
                        } else {
                            resetSlots('-- Không có khung giờ trống hoặc chưa có lịch làm việc --');
                        }
                    }
                ).fail(function () {
                    resetSlots('-- Lỗi khi tải khung giờ --');
                    if (typeof toastr !== 'undefined') {
                        toastr.error('Không thể tải khung giờ khám.');
                    }
                });
            }

            $specialtySelect.on('change', function () {
                loadDoctors();
            });

            $doctorSelect.on('change', function () {
                loadSlots();
            });

            $dateInput.on('change', function () {
                loadSlots();
            });

            if ($specialtySelect.val()) {
                loadDoctors(function () {
                    var currentDoctorId = '@Model.DoctorId';
                    if (currentDoctorId) {
                        $doctorSelect.val(currentDoctorId);
                    }

                    if ($doctorSelect.val() && $dateInput.val()) {
                        loadSlots();

                        setTimeout(function () {
                            var currentSlotId = '@Model.DoctorScheduleSlotId';
                            if (currentSlotId) {
                                $slotSelect.val(currentSlotId);
                            }
                        }, 300);
                    }
                });
            }
        });
    </script>

    @if (ViewBag.ToastErrors != null)
    {
        <script>
            $(function () {
                var errors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ToastErrors));
                if (errors && errors.length && typeof toastr !== 'undefined') {
                    errors.forEach(function (err) {
                        toastr.error(err);
                    });
                }
            });
        </script>
    }
}