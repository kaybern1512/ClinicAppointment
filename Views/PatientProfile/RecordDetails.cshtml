@model ClinicBookingMVC.Models.Appointment
@{
    ViewData["Title"] = "Chi tiết Bệnh án";
    var medicalRecord = ViewBag.MedicalRecord as ClinicBookingMVC.Models.MedicalRecord;
}

<div class="mb-4">
    <a asp-action="MyRecords" class="text-decoration-none text-muted">
        <i class="bi bi-arrow-left"></i> Quay lại Danh sách Hồ sơ
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <h5 class="card-title fw-bold border-bottom pb-3 mb-4 text-primary">Thông tin ca khám</h5>
                
                <div class="mb-3">
                    <small class="text-muted d-block">Mã ca khám</small>
                    <span class="fw-semibold fs-5">#@Model.AppointmentId</span>
                </div>
                
                <div class="mb-3">
                    <small class="text-muted d-block">Thời gian khám</small>
                    <span class="fw-medium">@Model.AppointmentTime.ToString(@"hh\:mm") - @Model.AppointmentDate.ToString("dd/MM/yyyy")</span>
                </div>

                <div class="mb-3">
                    <small class="text-muted d-block">Bên nhân</small>
                    <span class="fw-medium">@Model.PatientName</span>
                </div>

                <hr />

                <div class="mb-3">
                    <small class="text-muted d-block">Bác sĩ phụ trách</small>
                    <div class="d-flex align-items-center mt-2">
                        <div class="avatar-sm bg-primary bg-opacity-10 text-primary rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; font-size: 1.2rem;">
                            <i class="bi bi-person-heart"></i>
                        </div>
                        <div>
                            <div class="fw-bold">@Model.Doctor.FullName</div>
                            <small class="text-muted">Khoa @Model.Specialty.SpecialtyName</small>
                        </div>
                    </div>
                </div>

                <div class="mb-0 mt-4">
                    <small class="text-muted d-block">Triệu chứng khai báo ban đầu</small>
                    <div class="p-3 bg-light rounded mt-2 text-dark">
                        @(string.IsNullOrEmpty(Model.Symptoms) ? "Không có dữ liệu" : Model.Symptoms)
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h4 class="card-title fw-bold text-success mb-0"><i class="bi bi-clipboard2-pulse me-2"></i>Hồ sơ Bệnh án</h4>
                @if (medicalRecord != null)
                {
                    <small class="text-muted mt-2 d-block">Cập nhật lần cuối: @medicalRecord.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                }
            </div>
            <div class="card-body p-4">
                @if (medicalRecord != null)
                {
                    <div class="record-section mb-4">
                        <h6 class="text-uppercase fw-bold text-muted mb-3"><i class="bi bi-activity text-primary me-2"></i>Chẩn đoán kết luận</h6>
                        <div class="p-4 rounded border-start border-primary border-4 bg-light text-dark fs-5">
                            @Html.Raw(medicalRecord.Diagnosis?.Replace("\n", "<br/>") ?? "Đang cập nhật...")
                        </div>
                    </div>

                    <div class="record-section mb-4">
                        <h6 class="text-uppercase fw-bold text-muted mb-3"><i class="bi bi-capsule text-danger me-2"></i>Đơn thuốc & Liều dùng</h6>
                        <div class="p-4 rounded border bg-white shadow-sm text-dark fs-6" style="min-height: 100px;">
                            @if (!string.IsNullOrEmpty(medicalRecord.Prescription))
                            {
                                @Html.Raw(medicalRecord.Prescription.Replace("\n", "<br/>"))
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Bác sĩ không kê đơn thuốc cho ca khám này.</span>
                            }
                        </div>
                    </div>

                    <div class="record-section">
                        <h6 class="text-uppercase fw-bold text-muted mb-3"><i class="bi bi-chat-square-text text-info me-2"></i>Lời dặn dò từ Bác sĩ</h6>
                        <div class="p-4 rounded border bg-info bg-opacity-10 text-dark fs-6" style="min-height: 80px;">
                            @if (!string.IsNullOrEmpty(medicalRecord.DoctorNotes))
                            {
                                @Html.Raw(medicalRecord.DoctorNotes.Replace("\n", "<br/>"))
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Không có lời dặn dò thêm.</span>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-folder-x text-muted mb-3" style="font-size: 4rem;"></i>
                        <h5 class="text-muted">Hồ sơ bệnh án chưa được cập nhật</h5>
                        <p class="text-muted mb-0">Vui lòng chờ bác sĩ hoàn tất nhập liệu hồ sơ khám bệnh của bạn. Thời gian cập nhật có thể kéo dài sau khi ca khám kết thúc.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
