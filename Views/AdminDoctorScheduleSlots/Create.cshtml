@model ClinicBookingMVC.ViewModels.Admin.AdminSlotCreateViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm slot";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="admin-form-card shadow-lg border-0">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 text-success rounded-circle mb-3" style="width: 64px; height: 64px;">
                    <i class="bi bi-clock-fill fs-2"></i>
                </div>
                <h4 class="fw-bold text-dark">Thêm slot làm việc</h4>
                <div class="badge bg-light text-dark border p-2 mt-1">
                    @Model.DoctorName — @Model.WorkDate.ToString("dd/MM/yyyy")
                </div>
            </div>

            <form asp-action="Create" method="post">
                <input asp-for="ScheduleId" type="hidden" />

                <div class="mb-4">
                    <label asp-for="TimeSlotId" class="form-label admin-form-label">Khung giờ</label>
                    <select asp-for="TimeSlotId" asp-items="Model.TimeSlots" class="form-select admin-input bg-light border-0 shadow-sm">
                        <option value="">-- Chọn khung giờ khám --</option>
                    </select>
                    <span asp-validation-for="TimeSlotId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="MaxAppointments" class="form-label admin-form-label">Giới hạn số bệnh nhân</label>
                    <input asp-for="MaxAppointments" type="number" min="1" max="20" class="form-control admin-input bg-light border-0 shadow-sm" />
                    <span asp-validation-for="MaxAppointments" class="text-danger small"></span>
                    <small class="text-muted d-block mt-1">Số lượng bệnh nhân tối đa có thể đặt trong khung giờ này.</small>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-success btn-lg shadow-sm py-3">
                        <i class="bi bi-plus-circle-fill me-2"></i>Xác nhận thêm slot
                    </button>
                    <a asp-action="Index" asp-route-scheduleId="@Model.ScheduleId" class="btn btn-outline-secondary border-0">
                        Hủy bỏ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
