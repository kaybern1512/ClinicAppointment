@model ClinicBookingMVC.ViewModels.Admin.AdminSlotCreateViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm slot";
}

<div class="admin-form-card">
    <h4 class="mb-4"><i class="bi bi-clock-fill me-2"></i>Thêm slot mới</h4>
    <p class="text-muted">
        <strong>@Model.DoctorName</strong> — Ngày: <strong>@Model.WorkDate.ToString("dd/MM/yyyy")</strong>
    </p>

    <form asp-action="Create" method="post">
        <input asp-for="ScheduleId" type="hidden" />

        <div class="mb-3">
            <label asp-for="TimeSlotId" class="form-label fw-semibold"></label>
            <select asp-for="TimeSlotId" asp-items="Model.TimeSlots" class="form-select">
                <option value="">-- Chọn khung giờ --</option>
            </select>
            <span asp-validation-for="TimeSlotId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="MaxAppointments" class="form-label fw-semibold"></label>
            <input asp-for="MaxAppointments" type="number" min="1" max="20" class="form-control" style="max-width: 200px;" />
            <span asp-validation-for="MaxAppointments" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Thêm</button>
            <a asp-action="Index" asp-route-scheduleId="@Model.ScheduleId" class="btn btn-outline-secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
