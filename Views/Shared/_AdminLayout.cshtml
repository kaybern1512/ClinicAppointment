@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Clinic Management</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-wrapper">
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <i class="bi bi-hospital"></i>
                @if (User.IsInRole("Admin"))
                {
                    <span>Clinic Admin</span>
                }
                else if (User.IsInRole("Doctor"))
                {
                    <span>Bác sĩ</span>
                }
            </div>

            <nav class="admin-menu">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="AdminDashboard" asp-action="Index">
                        <i class="bi bi-grid"></i> Dashboard
                    </a>
                    <a asp-controller="AdminDoctors" asp-action="Index">
                        <i class="bi bi-person-badge"></i> Quản lý bác sĩ
                    </a>
                    <a asp-controller="AdminSpecialties" asp-action="Index">
                        <i class="bi bi-list-task"></i> Quản lý chuyên khoa
                    </a>
                    <a asp-controller="AdminAppointments" asp-action="Index">
                        <i class="bi bi-calendar-check"></i> Quản lý lịch hẹn
                    </a>
                    <a asp-controller="AdminUsers" asp-action="Index">
                        <i class="bi bi-people"></i> Quản lý người dùng
                    </a>
                    <a asp-controller="AdminContacts" asp-action="Index">
                        <i class="bi bi-envelope"></i> Tin nhắn liên hệ
                    </a>
                }
                else if (User.IsInRole("Doctor"))
                {
                    <a asp-controller="DoctorDashboard" asp-action="Index">
                        <i class="bi bi-grid"></i> Bảng điều khiển
                    </a>
                    // Add more doctor-specific links here in the future
                }
                <a asp-controller="Home" asp-action="Index">
                    <i class="bi bi-arrow-left-circle"></i> Về trang người dùng
                </a>
            </nav>
        </aside>

        <div class="admin-main">
            <header class="admin-topbar">
                <div>
                    @if (User.IsInRole("Admin"))
                    {
                        <h4 class="mb-0">Admin Dashboard</h4>
                        <small class="text-muted">Quản trị hệ thống đặt lịch phòng khám</small>
                    }
                    else if (User.IsInRole("Doctor"))
                    {
                        <h4 class="mb-0">Bảng điều khiển Bác sĩ</h4>
                        <small class="text-muted">Quản lý công việc và lịch hẹn của bạn</small>
                    }
                </div>
                <div class="admin-topbar-right">
                    <span class="admin-avatar">
                        <i class="bi bi-person-circle"></i>
                    </span>
                    <span class="fw-semibold">@(UserManager.GetUserName(User))</span>
                    <form asp-area="Identity" asp-controller="Account" asp-action="Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" id="logoutForm" class="d-inline">
                         <button type="submit" class="btn btn-outline-primary btn-sm">Đăng xuất</button>
                    </form>
                </div>
            </header>

            <main class="admin-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>