@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var roleName = HttpContextAccessor.HttpContext?.Session.GetString("RoleName");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Clinic Management</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-wrapper">
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <i class="bi bi-hospital"></i>
                @if (roleName == "Admin")
                {
                    <span>Clinic Admin</span>
                }
                else if (roleName == "Doctor")
                {
                    <span>Bác sĩ</span>
                }
            </div>

            <nav class="admin-menu">
                @if (roleName == "Admin")
                {
                    <a asp-controller="AdminDashboard" asp-action="Index"
                       class="@IsActive("AdminDashboard")">
                        <i class="bi bi-grid"></i> Dashboard
                    </a>
                    <a asp-controller="AdminDoctors" asp-action="Index"
                       class="@IsActive("AdminDoctors")">
                        <i class="bi bi-person-badge"></i> Quản lý bác sĩ
                    </a>
                    <a asp-controller="AdminSpecialties" asp-action="Index"
                       class="@IsActive("AdminSpecialties")">
                        <i class="bi bi-list-task"></i> Quản lý chuyên khoa
                    </a>
                    <a asp-controller="AdminAppointments" asp-action="Index"
                       class="@IsActive("AdminAppointments")">
                        <i class="bi bi-calendar-check"></i> Quản lý lịch hẹn
                    </a>
                    <a asp-controller="AdminDoctorSchedules" asp-action="Index"
                       class="@IsActive("AdminDoctorSchedules", "AdminDoctorScheduleSlots")">
                        <i class="bi bi-calendar-week"></i> Lịch bác sĩ & Slot
                    </a>
                    <a asp-controller="AdminUsers" asp-action="Index"
                       class="@IsActive("AdminUsers")">
                        <i class="bi bi-people"></i> Quản lý người dùng
                    </a>
                    <a asp-controller="AdminContacts" asp-action="Index"
                       class="@IsActive("AdminContacts")">
                        <i class="bi bi-envelope"></i> Tin nhắn liên hệ
                    </a>
                }
                else if (roleName == "Doctor")
                {
                    <a asp-controller="DoctorDashboard" asp-action="Index"
                       class="@IsActive("DoctorDashboard", null, "Index")">
                        <i class="bi bi-grid"></i> Bảng điều khiển
                    </a>
                    <a asp-controller="DoctorDashboard" asp-action="MySchedules"
                       class="@IsActive("DoctorDashboard", null, "MySchedules", "ScheduleDetails")">
                        <i class="bi bi-calendar-week"></i> Lịch làm việc
                    </a>
                }
                <a asp-controller="Home" asp-action="Index">
                    <i class="bi bi-arrow-left-circle"></i> Về trang người dùng
                </a>
            </nav>
        </aside>

        <div class="admin-main">
            <header class="admin-topbar">
                <div>
                    @if (roleName == "Admin")
                    {
                        <h4 class="mb-0">Admin Dashboard</h4>
                        <small class="text-muted">Quản trị hệ thống đặt lịch phòng khám</small>
                    }
                    else if (roleName == "Doctor")
                    {
                        <h4 class="mb-0">Bảng điều khiển Bác sĩ</h4>
                        <small class="text-muted">Quản lý công việc và lịch hẹn của bạn</small>
                    }
                </div>
                <div class="admin-topbar-right">
                    <span class="admin-avatar">
                        <i class="bi bi-person-circle"></i>
                    </span>
                    <span class="fw-semibold">@HttpContextAccessor.HttpContext?.Session.GetString("UserFullName")</span>
                    <form asp-controller="Account" asp-action="Logout" method="get" class="d-inline ms-2">
                        <button type="submit" class="btn btn-outline-primary btn-sm">Đăng xuất</button>
                    </form>
                </div>
            </header>

            <main class="admin-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="bi bi-check-circle me-1"></i>@TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="bi bi-exclamation-triangle me-1"></i>@TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.ErrorMessage
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@functions {
    private string GetCurrentController() =>
        ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    private string GetCurrentAction() =>
        ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    public string IsActive(string controller, string? altController = null, params string[] actions)
    {
        var currentController = GetCurrentController();
        var currentAction = GetCurrentAction();

        bool controllerMatch = currentController == controller ||
                               (altController != null && currentController == altController);

        if (!controllerMatch) return "";

        if (actions.Length == 0) return "active";

        return actions.Contains(currentAction) ? "active" : "";
    }
}