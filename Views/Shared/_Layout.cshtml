<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Clinic Booking</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark clinic-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-hospital me-2"></i>ClinicBooking
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Doctors" asp-action="Index">Bác sĩ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Specialties" asp-action="Index">Chuyên khoa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Appointments" asp-action="Create">Đặt lịch</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Appointments" asp-action="MyAppointments">Lịch hẹn của tôi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="PatientProfile" asp-action="MyRecords">Hồ sơ bệnh án</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">Liên hệ</a>
                        </li>

                        @if (Context.Session.GetString("UserEmail") == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm ms-lg-2" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <span class="nav-link text-warning">
                                    Xin chào, @Context.Session.GetString("UserFullName")
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm ms-lg-2" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="py-4">
        <div class="container">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }

            @RenderBody()
        </div>
    </main>

    <footer class="clinic-footer mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5>ClinicBooking</h5>
                    <p>Địa chỉ: 123 Nguyễn Văn Linh, Đà Nẵng</p>
                </div>
                <div class="col-md-4">
                    <h5>Liên hệ</h5>
                    <p>Số điện thoại: 0909 999 999</p>
                    <p>Email: support@clinicbooking.com</p>
                </div>
                <div class="col-md-4">
                    <h5>Giờ làm việc</h5>
                    <p>Thứ 2 - Thứ 7: 07:30 - 17:30</p>
                    <p>Chủ nhật: 08:00 - 12:00</p>
                </div>
            </div>
            <hr />
            <p class="mb-0 text-center">&copy; 2026 ClinicBooking. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>