<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Clinic Booking</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Toastr CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark clinic-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-hospital me-2"></i>ClinicBooking
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Doctors" asp-action="Index">
                                <i class="bi bi-person-heart me-1"></i>Bác sĩ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Specialties" asp-action="Index">
                                <i class="bi bi-grid-1x2 me-1"></i>Chuyên khoa
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 fw-bold text-primary bg-white rounded-pill ms-lg-2 shadow-sm border"
                               asp-controller="Appointments" asp-action="Create">
                                <i class="bi bi-calendar-plus me-1"></i>Đặt lịch ngay
                            </a>
                        </li>

                        <li class="nav-item dropdown ms-lg-3">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i>Cá nhân
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 p-2">
                                <li>
                                    <a class="dropdown-item rounded-3" asp-controller="Appointments" asp-action="MyAppointments">
                                        <i class="bi bi-calendar-check me-2"></i>Lịch hẹn của tôi
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item rounded-3" asp-controller="PatientProfile" asp-action="MyRecords">
                                        <i class="bi bi-file-earmark-medical me-2"></i>Hồ sơ bệnh án
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item rounded-3" asp-controller="Home" asp-action="Contact">
                                        <i class="bi bi-envelope me-2"></i>Liên hệ hỗ trợ
                                    </a>
                                </li>
                            </ul>
                        </li>

                        @if (Context.Session.GetString("UserEmail") == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm ms-lg-2" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                        else
                        {
                            @if (Context.Session.GetString("RoleName") == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminDashboard" asp-action="Index">
                                        <i class="bi bi-gear me-1"></i>Quản trị
                                    </a>
                                </li>
                            }

                            @if (Context.Session.GetString("RoleName") == "Doctor")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="DoctorDashboard" asp-action="Index">
                                        <i class="bi bi-clipboard2-pulse me-1"></i>Bảng điều khiển
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <span class="nav-link text-warning">
                                    Xin chào, @Context.Session.GetString("UserFullName")
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm ms-lg-2" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="py-4">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="clinic-footer mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5>ClinicBooking</h5>
                    <p>Địa chỉ: 123 Nguyễn Văn Linh, Đà Nẵng</p>
                </div>
                <div class="col-md-4">
                    <h5>Liên hệ</h5>
                    <p>Số điện thoại: 0909 999 999</p>
                    <p>Email: support@clinicbooking.com</p>
                </div>
                <div class="col-md-4">
                    <h5>Giờ làm việc</h5>
                    <p>Thứ 2 - Thứ 7: 07:30 - 17:30</p>
                    <p>Chủ nhật: 08:00 - 12:00</p>
                </div>
            </div>
            <hr />
            <p class="mb-0 text-center">&copy; 2026 ClinicBooking. All rights reserved.</p>
        </div>
    </footer>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Toastr JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <!-- Chatbox -->
    <link rel="stylesheet" href="~/css/chatbox.css" asp-append-version="true" />
    <script src="~/js/chatbox.js" asp-append-version="true"></script>

    <script>
        toastr.options = {
            closeButton: true,
            progressBar: true,
            newestOnTop: true,
            preventDuplicates: true,
            positionClass: "toast-top-right",
            timeOut: 3500,
            extendedTimeOut: 1200
        };
    </script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            $(function () {
                toastr.success('@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(TempData["SuccessMessage"]!.ToString()))');
            });
        </script>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            $(function () {
                toastr.error('@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(TempData["ErrorMessage"]!.ToString()))');
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>