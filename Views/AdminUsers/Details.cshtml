@model ClinicBookingMVC.ViewModels.Admin.AdminUserDetailsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết người dùng";
}

<div class="admin-details-card mb-4">
    <h4 class="mb-4">Thông tin người dùng</h4>

    <div class="row g-3">
        <div class="col-md-6"><strong>Họ tên:</strong> @Model.FullName</div>
        <div class="col-md-6"><strong>Email:</strong> @Model.Email</div>
        <div class="col-md-6"><strong>Số điện thoại:</strong> @Model.PhoneNumber</div>
        <div class="col-md-6"><strong>Vai trò:</strong> @Model.RoleName</div>
        <div class="col-md-6"><strong>Trạng thái:</strong> @(Model.IsActive ? "Active" : "Inactive")</div>
        <div class="col-md-6"><strong>Ngày tạo:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
    </div>
    </div>

    <div class="mb-4 p-3 bg-light rounded border">
        <h6><i class="bi bi-toggle-on me-2"></i>Quản lý trạng thái tài khoản</h6>
        <div class="d-flex align-items-center mb-2">
            <span class="badge fs-6 me-3 @(Model.IsActive ? "bg-success" : "bg-secondary")">
                @(Model.IsActive ? "Đang hoạt động" : "Bị khóa")
            </span>
            <button class="toggle-active-btn btn @(Model.IsActive ? "btn-outline-success" : "btn-outline-danger")" 
                    data-user-id="@Model.UserId" 
                    data-current-status="@Model.IsActive"
                    title="@(Model.IsActive ? "Khóa tài khoản này" : "Kích hoạt tài khoản này")">
                <i class="bi @(Model.IsActive ? "bi-unlock-fill" : "bi-lock-fill") me-1"></i>
                @(Model.IsActive ? "Khóa tài khoản" : "Kích hoạt")
            </button>
        </div>
        <small class="text-muted">Thao tác này sẽ @(Model.IsActive ? "khóa" : "kích hoạt") tài khoản ngay lập tức.</small>
    </div>

<div class="admin-section-card">
    <h5 class="mb-3">Lịch hẹn liên quan</h5>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Mã</th>
                    <th>Bệnh nhân</th>
                    <th>Bác sĩ</th>
                    <th>Chuyên khoa</th>
                    <th>Ngày khám</th>
                    <th>Giờ khám</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Appointments)
                {
                    <tr>
                        <td>#@item.AppointmentId</td>
                        <td>@item.PatientName</td>
                        <td>@item.DoctorName</td>
                        <td>@item.SpecialtyName</td>
                        <td>@item.AppointmentDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.AppointmentTime.ToString("HH:mm")</td>
                        <td>@item.StatusName</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary me-2">Quay lại</a>
        <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-warning me-2">Sửa</a>
        <a asp-action="Delete" asp-route-id="@Model.UserId" class="btn btn-danger">Xóa</a>
    </div>

</div>