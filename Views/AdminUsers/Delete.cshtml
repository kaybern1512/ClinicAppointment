@model ClinicBookingMVC.Models.User
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xóa người dùng";
}

<div class="admin-section-card">
    <h4>Xác nhận vô hiệu hóa</h4>
    <div class="alert alert-warning">
        <h5>@Model.FullName</h5>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Vai trò:</strong> @Model.Role.RoleName</p>
        <p class="mb-0">Bạn có chắc muốn vô hiệu hóa tài khoản này? (Đặt IsActive = false)</p>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="UserId" />
        <div class="btn-group">
            <button type="submit" class="btn btn-danger">Vô hiệu hóa</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </div>
    </form>
</div>
