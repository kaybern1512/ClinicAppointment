@model ClinicBookingMVC.ViewModels.Admin.AdminAppointmentEditStatusViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cập nhật trạng thái";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="admin-form-card shadow-lg border-0">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 64px; height: 64px;">
                    <i class="bi bi-arrow-repeat fs-2"></i>
                </div>
                <h4 class="fw-bold text-dark">Cập nhật trạng thái</h4>
                <p class="text-muted small">Lịch hẹn #@Model.AppointmentId</p>
            </div>

            <form asp-action="EditStatus" method="post">
                <input asp-for="AppointmentId" type="hidden" />

                <div class="mb-4">
                    <label asp-for="StatusId" class="form-label admin-form-label">Trạng thái mới</label>
                    <select asp-for="StatusId" asp-items="Model.Statuses" class="form-select admin-input shadow-sm border-0 bg-light"></select>
                    <span asp-validation-for="StatusId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Note" class="form-label admin-form-label">Ghi chú / Lý do</label>
                    <textarea asp-for="Note" class="form-control admin-input shadow-sm border-0 bg-light" rows="3" placeholder="Nhập lý do thay đổi (ví dụ: Đã xác nhận qua điện thoại)"></textarea>
                    <span asp-validation-for="Note" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg shadow-sm py-3">
                        <i class="bi bi-check-circle-fill me-2"></i>Lưu thay đổi
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.AppointmentId" class="btn btn-outline-secondary border-0">
                        Quay lại chi tiết
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}