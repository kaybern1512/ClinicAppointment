@model ClinicBookingMVC.ViewModels.Admin.AdminAppointmentEditStatusViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cập nhật trạng thái";
}

<div class="admin-form-card">
    <h4 class="mb-4">Cập nhật trạng thái lịch hẹn</h4>

    <form asp-action="EditStatus" method="post">
        <input asp-for="AppointmentId" type="hidden" />

        <div class="mb-3">
            <label asp-for="StatusId" class="form-label"></label>
            <select asp-for="StatusId" asp-items="Model.Statuses" class="form-select"></select>
            <span asp-validation-for="StatusId" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}