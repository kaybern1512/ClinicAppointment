@model ClinicBookingMVC.ViewModels.Admin.AdminAppointmentEditStatusViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cập nhật trạng thái";
}

<div class="admin-form-card">
    <h4 class="mb-4"><i class="bi bi-arrow-repeat me-2"></i>Cập nhật trạng thái lịch hẹn #@Model.AppointmentId</h4>

    <form asp-action="EditStatus" method="post">
        <input asp-for="AppointmentId" type="hidden" />

        <div class="mb-3">
            <label asp-for="StatusId" class="form-label fw-semibold"></label>
            <select asp-for="StatusId" asp-items="Model.Statuses" class="form-select"></select>
            <span asp-validation-for="StatusId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Note" class="form-label fw-semibold"></label>
            <textarea asp-for="Note" class="form-control" rows="3" placeholder="Nhập lý do thay đổi trạng thái (không bắt buộc)"></textarea>
            <span asp-validation-for="Note" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Lưu thay đổi</button>
            <a asp-action="Details" asp-route-id="@Model.AppointmentId" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}