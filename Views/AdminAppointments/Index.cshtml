@model IEnumerable<ClinicBookingMVC.ViewModels.Admin.AdminAppointmentListItemViewModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý lịch hẹn";
}

<div class="admin-section-card mb-4">
    <form method="get" asp-action="Index">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Từ khóa</label>
                <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control" placeholder="Tên bệnh nhân / mã lịch hẹn" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Trạng thái</label>
                <select name="statusId" asp-items="ViewBag.StatusId" class="form-select">
                    <option value="">-- Tất cả --</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Chuyên khoa</label>
                <select name="specialtyId" asp-items="ViewBag.SpecialtyId" class="form-select">
                    <option value="">-- Tất cả --</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Bác sĩ</label>
                <select name="doctorId" asp-items="ViewBag.DoctorId" class="form-select">
                    <option value="">-- Tất cả --</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Ngày khám</label>
                <input type="date" name="appointmentDate" value="@ViewBag.AppointmentDate" class="form-control" />
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button class="btn btn-primary w-100">Lọc</button>
            </div>
        </div>
    </form>
</div>

<div class="admin-section-card">
    <h5 class="mb-3">Danh sách lịch hẹn</h5>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Mã</th>
                    <th>Bệnh nhân</th>
                    <th>Bác sĩ</th>
                    <th>Chuyên khoa</th>
                    <th>Ngày khám</th>
                    <th>Giờ khám</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.AppointmentId</td>
                        <td>@item.PatientName</td>
                        <td>@item.DoctorName</td>
                        <td>@item.SpecialtyName</td>
                        <td>@item.AppointmentDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.AppointmentTime.ToString("HH:mm")</td>
                        <td>
                            <span class="@GetStatusBadge(item.StatusName)">@item.StatusName</span>
                        </td>
                        <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.AppointmentId" class="btn btn-outline-secondary btn-sm">Chi tiết</a>
                                <a asp-action="EditStatus" asp-route-id="@item.AppointmentId" class="btn btn-primary btn-sm">Trạng thái</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    public string GetStatusBadge(string statusName)
    {
        return statusName switch
        {
            "Pending" => "badge bg-warning text-dark",
            "Confirmed" => "badge bg-primary",
            "Completed" => "badge bg-secondary",
            "Cancelled" => "badge bg-danger",
            _ => "badge bg-dark"
        };
    }
}