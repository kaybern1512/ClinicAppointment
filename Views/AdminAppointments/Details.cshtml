@model ClinicBookingMVC.ViewModels.Admin.AdminAppointmentDetailsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết lịch hẹn";
}

<div class="admin-details-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0"><i class="bi bi-clipboard2-pulse me-2"></i>Chi tiết lịch hẹn #@Model.AppointmentId</h4>
        <span class="@GetStatusBadge(Model.StatusName) fs-6">@Model.StatusName</span>
    </div>

    <div class="row g-3">
        <div class="col-md-6"><strong>Mã đặt lịch:</strong> @Model.BookingCode</div>
        <div class="col-md-6"><strong>Bệnh nhân:</strong> @Model.PatientName</div>
        <div class="col-md-6"><strong>Số điện thoại:</strong> @Model.PhoneNumber</div>
        <div class="col-md-6"><strong>Email:</strong> @Model.Email</div>
        <div class="col-md-6"><strong>Bác sĩ:</strong> @Model.DoctorName</div>
        <div class="col-md-6"><strong>Chuyên khoa:</strong> @Model.SpecialtyName</div>
        <div class="col-md-6"><strong>Ngày khám:</strong> @Model.AppointmentDate.ToString("dd/MM/yyyy")</div>
        <div class="col-md-6"><strong>Giờ khám:</strong> @Model.AppointmentTime.ToString("HH:mm")</div>
        <div class="col-md-6"><strong>Ngày tạo:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
        @if (!string.IsNullOrEmpty(Model.Symptoms))
        {
            <div class="col-12"><strong>Triệu chứng:</strong> @Model.Symptoms</div>
        }
        @if (!string.IsNullOrEmpty(Model.Note))
        {
            <div class="col-12"><strong>Ghi chú:</strong> @Model.Note</div>
        }
    </div>

    <div class="mt-4 d-flex gap-2">
        <a asp-action="EditStatus" asp-route-id="@Model.AppointmentId" class="btn btn-primary">
            <i class="bi bi-arrow-repeat me-1"></i>Cập nhật trạng thái
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
    </div>
</div>

@if (Model.StatusHistories.Any())
{
    <div class="admin-section-card mt-4">
        <h5 class="mb-3"><i class="bi bi-clock-history me-2"></i>Lịch sử thay đổi trạng thái</h5>
        <div class="table-responsive">
            <table class="table admin-table align-middle">
                <thead>
                    <tr>
                        <th>Thời gian</th>
                        <th>Trạng thái cũ</th>
                        <th></th>
                        <th>Trạng thái mới</th>
                        <th>Người thay đổi</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in Model.StatusHistories)
                    {
                        <tr>
                            <td>@h.ChangedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (h.OldStatusName != null)
                                {
                                    <span class="@GetStatusBadge(h.OldStatusName)">@h.OldStatusName</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-center"><i class="bi bi-arrow-right"></i></td>
                            <td><span class="@GetStatusBadge(h.NewStatusName)">@h.NewStatusName</span></td>
                            <td>@h.ChangedByName</td>
                            <td>@(h.Note ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@functions {
    public string GetStatusBadge(string statusName)
    {
        return statusName switch
        {
            "Pending" => "badge bg-warning text-dark",
            "Confirmed" => "badge bg-primary",
            "Completed" => "badge bg-success",
            "Cancelled" => "badge bg-danger",
            _ => "badge bg-secondary"
        };
    }
}