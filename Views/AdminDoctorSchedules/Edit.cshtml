@model ClinicBookingMVC.ViewModels.Admin.AdminScheduleEditViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Sửa lịch làm việc";
}

<div class="admin-form-card">
    <h4 class="mb-4"><i class="bi bi-calendar-check me-2"></i>Sửa lịch làm việc</h4>

    <form asp-action="Edit" method="post">
        <input asp-for="ScheduleId" type="hidden" />
        <input asp-for="DoctorId" type="hidden" />

        <div class="mb-3">
            <label class="form-label fw-semibold">Bác sĩ</label>
            <input type="text" class="form-control" value="@Model.DoctorName" disabled />
        </div>

        <div class="mb-3">
            <label asp-for="WorkDate" class="form-label fw-semibold"></label>
            <input asp-for="WorkDate" type="date" class="form-control" />
            <span asp-validation-for="WorkDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Notes" class="form-label fw-semibold"></label>
            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Notes" class="text-danger"></span>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="IsAvailable" class="form-check-input" />
            <label asp-for="IsAvailable" class="form-check-label"></label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Lưu thay đổi</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
